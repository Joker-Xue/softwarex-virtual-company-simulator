# =============================================
# Career Planner API environment variable configuration
# Version：v2.0.0-release (2026-02-26)
# =============================================

# ---------- Databaseconfiguration ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/career_planner
# Use the following variables when deploying Docker（docker-compose.yml automatically assembles the connection string）
DB_USER=career_planner
DB_PASSWORD=career_planner_2026
DB_NAME=career_planner

# ---------- Redisconfiguration ----------
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# ---------- JWTAuthentication configuration ----------
# ⚠️ The production environment must be modified to a random string
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# The JWT key variable name used when Docker is deployed
JWT_SECRET_KEY=career-planner-jwt-secret-2026

# ---------- CORSconfiguration ----------
# Multiple domain names separated by commas，Please set the production environment to a specific domain name
# Local development uniformly uses localhost as a baseline；The backend will be automatically compatible 127.0.0.1 / ::1 loopback alias
CORS_ORIGINS=http://localhost:5174,http://127.0.0.1:5174

# ---------- Large model configuration ----------
# ⚠️ A valid API Key must be filled in
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_CACHE_TTL=86400
# Multi-model polling pool（comma separated，Leave blank to use only LLM_MODEL）
LLM_POOL=DeepSeek-V3.2,GLM-4.5-Air,Qwen3-32B,ERNIE-4.5-300B-A47B,Hunyuan-A13B-Instruct
LLM_POOL_COOLDOWN=60
LLM_MAX_CONCURRENCY=5

# ---------- Resume Optimization Quality Access Configuration ----------
# turn control：Perform at least MIN_ROUNDS rounds，Execute at most MAX_ROUNDS rounds
RESUME_OPTIMIZE_MIN_ROUNDS=2
RESUME_OPTIMIZE_MAX_ROUNDS=3
# Quality level：balanced / strict
RESUME_OPTIMIZE_QUALITY_PROFILE=balanced
# Threshold parameter adjustment（for grayscale，can be sorted by needs to be covered；Use the gear default value when not configured.）
RESUME_OPTIMIZE_MIN_ITEMS=5
RESUME_OPTIMIZE_MIN_SECTION_DIVERSITY=3
RESUME_OPTIMIZE_MIN_KEYWORDS=6
RESUME_OPTIMIZE_MIN_PRIORITY_ACTIONS=5

# ---------- Real LLM smoke test ----------
# defaultclosed；Turn on before launch or when returning daily
RUN_LIVE_LLM_TESTS=0

# ---------- Tianxing data（TianAPI）configuration ----------
# register: https://www.tianapi.com/  Free 500 times/day
TIANAPI_KEY=your-tianapi-key

# ---------- SMTP email configuration ----------
# SMTP_PASSWORD is an authorization code, not the mailbox login password.
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-shared-mailbox@example.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM=your-shared-mailbox@example.com
SMTP_DISPLAY_NAME=Virtual Company Simulator
SMTP_USE_SSL=true
